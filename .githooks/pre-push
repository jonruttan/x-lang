#!/bin/sh
# Pre-push gate -- block a push when the suite is red.
#
# GitHub Actions re-runs the same surface on push/PR (.github/workflows/
# ci.yml: contract gates + test-c + test-x as separate steps),
# but this hook is the gate that catches a red suite BEFORE it leaves the
# machine (see docs/contributing.md). Install with `make install-hooks` (sets
# core.hooksPath=.githooks). Bypass a single push with `git push --no-verify`.
#
# RUN_ASAN=1 additionally runs `make test-asan` as a NON-BLOCKING advisory.
# The baseline is clean and CI hard-gates it on every push; locally it stays
# opt-in only because instrumentation makes it ~2-3x slower than the gate.

root=$(git rev-parse --show-toplevel) || exit 1
cd "$root" || exit 1

# Hard gate: both suites (test-c + test-x), green at HEAD. A regression blocks.
printf '[pre-push] make test ...\n'
if ! make test; then
	printf '\n[pre-push] BLOCKED: `make test` is red. Fix it, or bypass with `git push --no-verify`.\n' >&2
	exit 1
fi

# Opt-in ASan pass (see header note): non-blocking locally for speed; CI is
# the enforcing gate for this one.
if [ -n "$RUN_ASAN" ]; then
	printf '\n[pre-push] RUN_ASAN -- make test-asan (advisory) ...\n'
	make test-asan || printf '[pre-push] note: test-asan RED -- the baseline is clean, so this is likely YOUR regression (CI will hard-fail it); not blocking locally.\n' >&2
fi

printf '[pre-push] OK\n'
exit 0
